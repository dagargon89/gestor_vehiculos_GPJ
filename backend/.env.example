# Database (Docker: postgres service)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleet_management
DB_USER=fleet_user
DB_PASSWORD=your_secure_password

# Redis (Docker: redis service)
REDIS_HOST=localhost
REDIS_PORT=6379

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Usuario admin creado por el seed (solo si FIREBASE_SERVICE_ACCOUNT_KEY está definido). Para primer acceso en producción.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin123

# Correo para notificaciones por email (SMTP). Si no se configuran, las notificaciones solo serán in-app.
MAIL_HOST=smtp.ejemplo.com
# 465 con TLS (recomendado para Gmail); 587 con STARTTLS si la red lo permite
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=notificaciones@planjuarez.org

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
