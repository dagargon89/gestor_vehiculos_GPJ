# Database (Docker: postgres service)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleet_management
DB_USER=fleet_user
DB_PASSWORD=your_secure_password

# Redis (Docker: redis service)
REDIS_HOST=localhost
REDIS_PORT=6379

# Firebase
FIREBASE_PROJECT_ID=proyecto-gestion-vehiculos
FIREBASE_STORAGE_BUCKET=proyecto-gestion-vehiculos.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# SendGrid (opcional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notificaciones@planjuarez.org

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
